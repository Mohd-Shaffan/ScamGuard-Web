# ── App Config ──────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins. Use "*" for development only.
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# Maximum text length in characters for analysis requests
MAX_TEXT_LENGTH=5000

# Maximum number of texts in a batch analysis request
MAX_BATCH_SIZE=50

# Session expiry time in seconds (default: 1 hour)
SESSION_MAX_AGE=3600

# WebSocket heartbeat timeout in seconds
WS_HEARTBEAT_TIMEOUT=60

# ── Server Config ──────────────────────────────────────────────
# Port to run the server on
PORT=8000

# Environment: "development" (enables reload) or "production"
ENV=development

# ── AI/ML Config ───────────────────────────────────────────────
# SentenceTransformer model name (must match training)
ENCODER_NAME=paraphrase-multilingual-MiniLM-L12-v2

# Default NLP score when model is unavailable (0.0 - 1.0)
DEFAULT_NLP_SCORE=0.30

# Whisper ASR model size: tiny, base, small, medium, large
WHISPER_MODEL_SIZE=base
